# Evolution API v2 production env — template
# Copy to infra/evolution/.env (which is gitignored) and fill in real values.
# On the Oracle VM, these become the environment for the compose stack.

# Public URL where the Evolution API is reachable (no trailing slash)
SERVER_URL=http://80.225.254.66:8080

# API key — MUST match EVOLUTION_API_KEY in Backend/.env (and Heroku config)
AUTHENTICATION_API_KEY=rozareplatform

# PostgreSQL (internal to the docker-compose network)
POSTGRES_DB=evolution
POSTGRES_USER=evolution
POSTGRES_PASSWORD=change-me-to-a-long-random-string
