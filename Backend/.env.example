# ========================================
# Rozare Backend - Environment Variables
# ========================================
# Copy this file to .env and fill in the values

# ---------- Core ----------
NODE_ENV=production
PORT=5000

# ---------- Database ----------
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ---------- Auth ----------
JWT_SECRET=your_jwt_secret_here

# ---------- Frontend URL (for CORS & email links) ----------
FRONTEND_URL=https://www.rozare.com

# ---------- Google OAuth ----------
clientID=your_google_client_id
clientSecret=your_google_client_secret
GOOGLE_CALLBACK_URL=https://your-heroku-app.herokuapp.com/api/auth/google/callback

# ---------- Stripe ----------
# Stripe Configuration
# Use test keys for development, live keys for production
STRIPE_MODE=test
STRIPE_TEST_SECRET_KEY=sk_test_xxx
STRIPE_LIVE_SECRET_KEY=sk_live_xxx
STRIPE_TEST_WEBHOOK_SECRET=whsec_test_xxx
STRIPE_LIVE_WEBHOOK_SECRET=whsec_live_xxx

# ---------- Cloudinary ----------
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ---------- Brevo (Email) ----------
BREVO_API_KEY=xkeysib-xxx
BREVO_SENDER_NAME=Rozare
BREVO_SENDER_EMAIL=noreply@rozare.com

# ---------- Optional ----------
# HF_API_KEY=hf_xxx
# TRUST_PROXY_HOPS=1

# ---------- TikTok Pixel + Events API ----------
# Pixel ID is public; Events API token is secret and must only live on the backend.
TIKTOK_PIXEL_ID=D85EEDJC77U42GL90IK0
TIKTOK_EVENTS_API_TOKEN=generate_this_in_tiktok_events_manager
# Optional: only set temporarily while using TikTok Test Events.
# TIKTOK_TEST_EVENT_CODE=TEST12345

# ---------- AI (OpenRouter) ----------
# Get your key at https://openrouter.ai/keys
# OpenRouter gives access to 100+ models (Gemini, Claude, GPT, etc.) with one key.
OPENROUTER_API_KEY=sk-or-v1-xxx
# Primary model used by the AI chat (any OpenRouter model id)
# Examples: google/gemini-2.5-flash, google/gemini-2.5-pro, anthropic/claude-3.5-sonnet, openai/gpt-4o-mini
AI_MODEL=google/gemini-2.5-flash
# Optional fallback model if primary fails
AI_FALLBACK_MODEL=google/gemini-flash-1.5

# ---------- WhatsApp / Evolution API (Oracle Cloud VM) ----------
# Evolution API is self-hosted on an Oracle Cloud Always-Free Ubuntu VM.
# See WHATSAPP_EVOLUTION_SETUP.md for the full deployment guide.
EVOLUTION_API_URL=http://YOUR_ORACLE_PUBLIC_IP:8080
EVOLUTION_API_KEY=rozareplatform
EVOLUTION_INSTANCE_NAME=rozare-main
WHATSAPP_WEBHOOK_SECRET=change_me
